# Kopiere diese Datei zu  .env  und trage deine Spotify-App-Daten ein.
# App anlegen:  https://developer.spotify.com/dashboard  (Create app)
# Redirect URI in der App exakt eintragen:  http://127.0.0.1:8888/callback

SPOTIPY_CLIENT_ID=deine_client_id
SPOTIPY_CLIENT_SECRET=dein_client_secret
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# OPTIONAL: Standard-Ordner für die "Extended Streaming History" (Download
# unter Account -> Datenschutz -> Erweiterte Streaming-History). Wenn gesetzt,
# ist er im Quelle-Picker vorausgefüllt und gilt für  python spotify.py --history
# SPOTIFY_HISTORY_DIR=/Pfad/zu/Spotify Extended Streaming History

# OPTIONAL: Spotify liefert seit 2026 keine Genres mehr (Dev-Mode-Apps).
# Genres werden daher extern geholt - standardmäßig via MusicBrainz (ohne Key,
# aber 1 Anfrage/Sekunde). Mit einem kostenlosen Last.fm-API-Key geht es
# schneller und mit besseren Tags:  https://www.last.fm/api/account/create
# LASTFM_API_KEY=dein_lastfm_key
